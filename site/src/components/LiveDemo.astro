---
import type { Locale } from '../i18n/utils';
import { useTranslations } from '../i18n/utils';

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<div class="section reveal" id="demo">
  <div class="container">
    <div class="section-label">{t.demoLabel}</div>
    <h2 class="section-title">{t.demoTitle}</h2>
    <p class="section-sub">{t.demoSubtitle}</p>

    <div class="demo-container">
      <!-- Chat conversation -->
      <div class="chat-thread">
        <div class="chat-message user">
          <div class="msg-bubble">{t.demoR1user}</div>
        </div>

        <div class="chat-message vibeflow">
          <div class="msg-bubble">
            <strong>{t.demoChallengeLabel}</strong>
            <ul>
              <li>{t.demoR2q1}</li>
              <li>{t.demoR2q2}</li>
              <li>{t.demoR2q3}</li>
            </ul>
          </div>
        </div>

        <div class="chat-message user">
          <div class="msg-bubble">{t.demoR2user}</div>
        </div>

        <div class="chat-message vibeflow">
          <div class="msg-bubble">
            <strong>{t.demoPushbackLabel}</strong>
            <ul>
              <li>{t.demoR3q1}</li>
              <li>{t.demoR3q2}</li>
            </ul>
          </div>
        </div>

        <div class="chat-message user">
          <div class="msg-bubble">{t.demoR3user}</div>
        </div>
      </div>

      <!-- Output cards -->
      <div class="demo-output">
        <div class="output-block">
          <div class="output-label">{t.demoR4label}</div>
          <div class="output-content">
            <div><span class="key">{t.demoOutputScope}</span> <span class="val">{t.demoR4scope}</span></div>
            <div class="mt"><span class="key">{t.demoOutputAntiScope}</span> <span class="dim">{t.demoR4antiscope}</span></div>
          </div>
        </div>

        <div class="output-block">
          <div class="output-label">{t.demoR5label}</div>
          <div class="output-content">
            <div><span class="check">☐</span> {t.demoR5dod1}</div>
            <div><span class="check">☐</span> {t.demoR5dod2}</div>
            <div><span class="check">☐</span> {t.demoR5dod3}</div>
            <div><span class="check">☐</span> {t.demoR5dod4}</div>
            <div class="mt"><span class="key">{t.demoOutputBudget}</span> <span class="val">{t.demoR5budget}</span></div>
          </div>
        </div>

        <div class="output-block">
          <div class="output-label">{t.demoR6label}</div>
          <div class="output-content">
            <div>{t.demoR6file1}</div>
            <div>{t.demoR6file2}</div>
            <div>{t.demoR6file3}</div>
            <div class="mt"><span class="check">✓</span> <span class="dim">{t.demoR6status}</span></div>
          </div>
        </div>

        <div class="output-block">
          <div class="output-label">{t.demoR7label} &rarr; {t.demoR7verdict}</div>
          <div class="output-content">
            <div><span class="check">✓</span> {t.demoR7dod1}</div>
            <div><span class="check">✓</span> {t.demoR7dod2}</div>
            <div><span class="check">✓</span> {t.demoR7dod3}</div>
            <div><span class="check">✓</span> {t.demoR7dod4}</div>
            <div><span class="check">✓</span> {t.demoR7patterns}</div>
            <div class="mt"><span class="check">{t.demoR7verdict}</span> <span class="dim">&mdash; {t.demoR7verdictDesc}</span></div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  .demo-container {
    background: var(--bg-card);
    border-radius: 20px;
    padding: 2rem;
    border: 1px solid var(--border);
  }

  .chat-thread {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-bottom: 1rem;
  }

  .chat-message {
    display: flex;
    gap: 0.75rem;
    max-width: 700px;
  }

  .chat-message.user {
    flex-direction: row-reverse;
    justify-content: flex-end;
  }

  .chat-message.vibeflow {
    justify-content: flex-start;
  }

  .msg-bubble {
    padding: 1rem 1.25rem;
    border-radius: 14px;
    font-size: 0.9rem;
    line-height: 1.6;
  }

  .chat-message.user .msg-bubble {
    background: var(--accent-glow);
    color: var(--text-primary);
    max-width: 420px;
    border: 1px solid var(--accent-glow-strong);
  }

  .chat-message.vibeflow .msg-bubble {
    background: var(--bg-primary);
    color: var(--text-primary);
    border: 1px solid var(--border);
    max-width: 520px;
  }

  .msg-bubble strong {
    display: block;
    margin-bottom: 0.5rem;
    font-weight: 600;
  }

  .msg-bubble ul {
    list-style: none;
    margin-top: 0.5rem;
  }

  .msg-bubble li {
    padding-left: 1.25rem;
    position: relative;
    margin-bottom: 0.35rem;
  }

  .msg-bubble li::before {
    content: '•';
    position: absolute;
    left: 0;
    color: var(--accent);
  }

  /* Output blocks */
  .demo-output {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
    margin-top: 1.25rem;
  }

  .output-block {
    background: var(--bg-code);
    border-radius: 12px;
    overflow: hidden;
    padding: 1.25rem;
  }

  .output-label {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--accent);
    margin-bottom: 0.75rem;
    font-weight: 600;
  }

  .output-content {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: #e5e5ea;
    line-height: 1.8;
  }

  .output-content .key { color: #818cf8; }
  .output-content .val { color: #a78bfa; }
  .output-content .check { color: #30d158; font-weight: 500; }
  .output-content .dim { color: #8e8e93; }
  .output-content .mt { margin-top: 0.5rem; }

  @media (max-width: 768px) {
    .demo-container {
      padding: 1.5rem 1.25rem;
    }
    .demo-output {
      grid-template-columns: 1fr;
    }
    .chat-message {
      max-width: 100%;
    }
    .chat-message.user .msg-bubble,
    .chat-message.vibeflow .msg-bubble {
      max-width: 100%;
    }
  }
</style>
